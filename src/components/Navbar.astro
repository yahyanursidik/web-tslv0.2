---
// Navbar Component
---
<!-- TopNavBar -->
<header class="bg-surface dark:bg-surface-dim border-b border-outline-variant dark:border-outline docked full-width top-0 sticky z-50">
    <nav class="flex justify-between items-center w-full px-margin-desktop max-w-max-width mx-auto h-20">
        <div class="flex items-center gap-sm">
            <span class="font-headline-md text-headline-md font-bold text-primary dark:text-primary-fixed-dim">Tarbiyah Sunnah Learning</span>
        </div>
        <div class="hidden md:flex items-center gap-lg">
            <a class="text-primary dark:text-primary-fixed-dim border-b-2 border-primary dark:border-primary-fixed-dim pb-1 font-bold font-label-md text-label-md" href="/">Home</a>
            <a class="text-on-surface-variant dark:text-outline-variant hover:text-primary dark:hover:text-primary-fixed-dim font-label-md text-label-md transition-colors duration-200" href="#">Programs</a>
            <a class="text-on-surface-variant dark:text-outline-variant hover:text-primary dark:hover:text-primary-fixed-dim font-label-md text-label-md transition-colors duration-200" href="#">Articles</a>
            <a class="text-on-surface-variant dark:text-outline-variant hover:text-primary dark:hover:text-primary-fixed-dim font-label-md text-label-md transition-colors duration-200" href="#">Schedule</a>
            <a class="text-on-surface-variant dark:text-outline-variant hover:text-primary dark:hover:text-primary-fixed-dim font-label-md text-label-md transition-colors duration-200" href="#">Contact</a>
        </div>
        <div class="flex items-center gap-sm">
            <button class="hidden lg:flex items-center px-sm py-xs font-label-md text-label-md text-primary hover:bg-surface-container-low transition-colors">
                Login LMS
            </button>
            <button class="bg-primary text-on-primary px-md py-xs rounded-full font-label-md text-label-md hover:opacity-90 active:scale-95 transition-all">
                Register
            </button>
            <span class="material-symbols-outlined text-primary cursor-pointer lg:hidden" data-icon="menu">menu</span>
        </div>
    </nav>
</header>
