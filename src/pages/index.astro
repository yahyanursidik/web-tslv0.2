<a class="text-primary font-label-md text-label-md underline" href="#">Lihat Semua</a>
</div>
<div class="space-y-sm">
<div class="bg-white p-md rounded-xl border border-outline-variant flex gap-md items-center">
<div class="bg-primary/5 text-primary p-sm rounded-lg text-center min-w-[80px]">
<div class="font-bold text-xl">15</div>
<div class="text-xs uppercase">Mei</div>
</div>
<div>
<h4 class="font-title-lg text-title-lg">Webinar: Pentingnya Adab Penuntut Ilmu</h4>
<p class="text-sm text-on-surface-variant">Pukul 20:00 WIB via Zoom</p>
</div>
</div>
<div class="bg-white p-md rounded-xl border border-outline-variant flex gap-md items-center">
<div class="bg-primary/5 text-primary p-sm rounded-lg text-center min-w-[80px]">
<div class="font-bold text-xl">18</div>
<div class="text-xs uppercase">Mei</div>
</div>
<div>
<h4 class="font-title-lg text-title-lg">Daurah Bahasa Arab Dasar Batch 2</h4>
<p class="text-sm text-on-surface-variant">Pukul 09:00 WIB via LMS TSL</p>
</div>
</div>
<div class="bg-white p-md rounded-xl border border-outline-variant flex gap-md items-center">
<div class="bg-primary/5 text-primary p-sm rounded-lg text-center min-w-[80px]">
<div class="font-bold text-xl">22</div>
<div class="text-xs uppercase">Mei</div>
</div>
<div>
<h4 class="font-title-lg text-title-lg">Open House Madrasah Anak Online</h4>
<p class="text-sm text-on-surface-variant">Pukul 16:00 WIB via Google Meet</p>
</div>
</div>
</div>
</div>
<!-- Latest Articles -->
<div>
<div class="flex justify-between items-end mb-md">
<h2 class="font-headline-md text-headline-md text-primary">Artikel Terbaru</h2>
<a class="text-primary font-label-md text-label-md underline" href="#">Baca Blog</a>
</div>
<div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-1 gap-sm">
<div class="flex gap-sm items-center bg-white p-sm rounded-xl border border-outline-variant">
<div class="w-20 h-20 bg-surface-container rounded-lg shrink-0 overflow-hidden">
